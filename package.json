{
  "name": "map-storage",
  "version": "0.1.3",
  "description": "Decky plugin to setup any plugged storage on Steam Deck (optional format + udisks2 automount)",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "rollup -c",
    "build:zip": "bash scripts/build-zip.sh",
    "build:ci": "bash scripts/ci-build-zip.sh",
    "watch": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evertonfxavier/map-storage.git"
  },
  "keywords": [
    "decky",
    "decky-plugin",
    "steam-deck",
    "nvme",
    "storage"
  ],
  "author": "Everton Xavier",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/evertonfxavier/map-storage/issues"
  },
  "homepage": "https://github.com/evertonfxavier/map-storage#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.4",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
